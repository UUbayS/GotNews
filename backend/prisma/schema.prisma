generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  name              String
  username          String?          @unique
  email             String           @unique
  password          String
  role              String           @default("user")
  avatarUrl         String?
  preferences       String           @default("[]")
  dateOfBirth       String?
  gender            String?
  address           String?
  latitude          Float?
  longitude         Float?
  countryCode       String?
  city              String?
  locationUpdatedAt DateTime?
  locationEnabled   Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastLoginAt       DateTime?
  bookmarks         Bookmark[]
  likes             Like[]
  notifications     Notification[]
  readingHistory    ReadingHistory[]
}

model Article {
  id              String                   @id @default(cuid())
  externalId      String                   @unique
  title           String
  originalContent String?
  summary         String
  sourceUrl       String?
  sourceName      String?
  imageUrl        String?
  category        String?
  language        String                   @default("en")
  country         String?
  publishedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  aiSummary       String?
  aiSummaryAt     DateTime?
  searchVector    Unsupported("tsvector")?
  bookmarks       Bookmark[]
  likes           Like[]
  readingHistory  ReadingHistory[]

  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@index([category])
  @@index([language])
  @@index([country])
}

model Bookmark {
  id          String               @id @default(cuid())
  userId      String
  articleId   String
  createdAt   DateTime             @default(now())
  article     Article              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderItems BookmarkFolderItem[]

  @@unique([userId, articleId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model InvalidatedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model NewsSource {
  id            String    @id @default(cuid())
  name          String
  sourceId      String    @unique
  language      String
  isActive      Boolean   @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model ReadingHistory {
  id           String   @id @default(cuid())
  userId       String
  articleId    String
  readAt       DateTime @default(now())
  readProgress Float    @default(0)
  durationSec  Int      @default(0)
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId, readAt(sort: Desc)])
}

model BookmarkFolder {
  id        String               @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  items     BookmarkFolderItem[]

  @@unique([userId, name])
  @@index([userId])
}

model BookmarkFolderItem {
  id         String         @id @default(cuid())
  folderId   String
  bookmarkId String
  createdAt  DateTime       @default(now())
  bookmark   Bookmark       @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  folder     BookmarkFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, bookmarkId])
  @@index([folderId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}
